{
  "name": "scriptbee",
  "displayName": "ScriptBee",
  "description": "ScriptBee is a tool that helps the analysis of different models with scripts written in C#, Javascript or Python.",
  "version": "0.0.1",
  "publisher": "dxworks",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxworks/scriptbee"
  },
  "bugs": {
    "url": "https://github.com/dxworks/scriptbee/issues"
  },
  "homepage": "https://dxworks.org/scriptbee",
  "license": "Apache-2.0",
  "icon": "assets/logo_bee.png",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "ScriptBee",
      "properties": {
        "scriptbee.workspaceRoot": {
          "type": "string",
          "default": "~/.scriptbee",
          "description": "The root folder where ScriptBee projects and generated code are stored."
        },
        "scriptbee.enableLiveUpdates": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time updates for script lifecycle events (creation, update, deletion)."
        },
        "scriptbee.enableAutoPush": {
          "type": "boolean",
          "default": true,
          "description": "Automatically push script changes to the server upon saving."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "scriptbee-explorer",
          "title": "ScriptBee",
          "icon": "assets/logo_bee.svg"
        }
      ]
    },
    "views": {
      "scriptbee-explorer": [
        {
          "id": "scriptbee-connections",
          "name": "Connections",
          "type": "tree",
          "icon": "assets/logo_bee.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "scriptbee.addConnection",
        "title": "ScriptBee: Add Connection",
        "icon": "$(add)"
      },
      {
        "command": "scriptbee.editConnection",
        "title": "ScriptBee: Edit Connection",
        "icon": "$(edit)"
      },
      {
        "command": "scriptbee.switchConnection",
        "title": "ScriptBee: Switch Connection",
        "icon": "$(check)"
      },
      {
        "command": "scriptbee.deleteConnection",
        "title": "ScriptBee: Delete Connection",
        "icon": "$(trash)"
      },
      {
        "command": "scriptbee.selectProject",
        "title": "ScriptBee: Select Project",
        "icon": "$(settings-gear)"
      },
      {
        "command": "scriptbee.refreshTreeView",
        "title": "ScriptBee: Refresh Tree View",
        "icon": "$(refresh)"
      },
      {
        "command": "scriptbee.syncScripts",
        "title": "ScriptBee: Sync Scripts",
        "icon": "$(sync)"
      },
      {
        "command": "scriptbee.pullScripts",
        "title": "ScriptBee: Pull Scripts",
        "icon": "$(cloud-download)"
      },
      {
        "command": "scriptbee.pullScript",
        "title": "ScriptBee: Pull Script",
        "icon": "$(cloud-download)"
      },
      {
        "command": "scriptbee.pushScripts",
        "title": "ScriptBee: Push Scripts",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "scriptbee.pushScript",
        "title": "ScriptBee: Push Script",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "scriptbee.openProjectFolder",
        "title": "ScriptBee: Open Project Folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "scriptbee.compareWithRemote",
        "title": "ScriptBee: Compare with Remote",
        "icon": "$(diff)"
      },
      {
        "command": "scriptbee.selectInstance",
        "title": "ScriptBee: Select Instance",
        "icon": "$(database)"
      },
      {
        "command": "scriptbee.generateClasses",
        "title": "ScriptBee: Generate Classes",
        "icon": "$(symbol-class)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "scriptbee.addConnection",
          "when": "view == scriptbee-connections",
          "group": "navigation@1"
        },
        {
          "command": "scriptbee.refreshTreeView",
          "when": "view == scriptbee-connections",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "scriptbee.switchConnection",
          "when": "view == scriptbee-connections && viewItem == connection",
          "group": "inline@1"
        },
        {
          "command": "scriptbee.selectProject",
          "when": "view == scriptbee-connections && (viewItem == connection || viewItem == connectionActive)",
          "group": "inline@2"
        },
        {
          "command": "scriptbee.editConnection",
          "when": "view == scriptbee-connections && (viewItem == connection || viewItem == connectionActive)",
          "group": "inline@3"
        },
        {
          "command": "scriptbee.deleteConnection",
          "when": "view == scriptbee-connections && (viewItem == connection || viewItem == connectionActive)",
          "group": "inline@4"
        },
        {
          "command": "scriptbee.syncScripts",
          "when": "view == scriptbee-connections && viewItem == project",
          "group": "inline@1"
        },
        {
          "command": "scriptbee.pullScripts",
          "when": "view == scriptbee-connections && viewItem == project",
          "group": "inline@2"
        },
        {
          "command": "scriptbee.pushScripts",
          "when": "view == scriptbee-connections && viewItem == project",
          "group": "inline@3"
        },
        {
          "command": "scriptbee.openProjectFolder",
          "when": "view == scriptbee-connections && viewItem == project",
          "group": "inline@4"
        },
        {
          "command": "scriptbee.selectInstance",
          "when": "view == scriptbee-connections && viewItem == project",
          "group": "inline@5"
        },
        {
          "command": "scriptbee.generateClasses",
          "when": "view == scriptbee-connections && viewItem == instance",
          "group": "inline@1"
        }
      ],
      "editor/context": [
        {
          "command": "scriptbee.compareWithRemote",
          "group": "scriptbee@1"
        },
        {
          "command": "scriptbee.pullScript",
          "group": "scriptbee@2"
        },
        {
          "command": "scriptbee.pushScript",
          "group": "scriptbee@3"
        }
      ],
      "explorer/context": [
        {
          "command": "scriptbee.compareWithRemote",
          "group": "scriptbee@1"
        },
        {
          "command": "scriptbee.pullScript",
          "group": "scriptbee@2"
        },
        {
          "command": "scriptbee.pushScript",
          "group": "scriptbee@3"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "package": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "tsc -watch -p ./",
    "pretest": "tsc -p ./ && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "prettier:fix": "prettier --write ."
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "axios": "^1.15.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "25.x",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "axios-mock-adapter": "^2.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.2",
    "sinon": "^21.1.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
