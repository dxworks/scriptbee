          "linkerIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "LoadContextCommand": {
        "required": [
          "filesToLoad"
        ],
        "type": "object",
        "properties": {
          "filesToLoad": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "PluginExtensionPoint": {
