          },
          {
            "$ref": "#/components/schemas/InstalledPluginExtensionPointOutletBaseInstalledPluginSidePanelOutlet"
          },
          {
            "$ref": "#/components/schemas/InstalledPluginExtensionPointOutletBaseInstalledPluginFilePreviewerOutlet"
          }
        ],
        "description": "Base class for outlets of a plugin extension point.",
        "discriminator": {
          "propertyName": "type"
        }
      },
      "InstalledPluginExtensionPointOutletBaseInstalledPluginFilePreviewerOutlet": {
        "required": [
          "exposedModule",
