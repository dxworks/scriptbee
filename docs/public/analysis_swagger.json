{
  "openapi": "3.1.1",
  "info": {
    "title": "Analysis.Web | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5002/"
    }
  ],
  "paths": {
    "/api/plugins": {
      "get": {
        "tags": ["Plugins"],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebGetInstalledPluginsResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Plugins"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebInstallPluginCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/plugins/{pluginId}": {
      "delete": {
        "tags": ["Plugins"],
        "parameters": [
          {
            "name": "pluginId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/api/context/clear": {
      "post": {
        "tags": ["Context"],
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/api/context/generate-classes": {
      "post": {
        "tags": ["Context"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebGenerateClassesRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/context": {
      "get": {
        "tags": ["Context"],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebGetContextResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/context/link": {
      "post": {
        "tags": ["Context"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebLinkContextCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/context/load": {
      "post": {
        "tags": ["Context"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebLoadContextCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/analyses": {
      "post": {
        "tags": ["Analysis"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebRunAnalysisCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebRunAnalysisResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HttpValidationProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": ["null", "string"]
          },
          "title": {
            "type": ["null", "string"]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": ["null", "integer", "string"],
            "format": "int32"
          },
          "detail": {
            "type": ["null", "string"]
          },
          "instance": {
            "type": ["null", "string"]
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": ["null", "string"]
          },
          "title": {
            "type": ["null", "string"]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": ["null", "integer", "string"],
            "format": "int32"
          },
          "detail": {
            "type": ["null", "string"]
          },
          "instance": {
            "type": ["null", "string"]
          }
        }
      },
      "WebContextSlice": {
        "required": ["model", "pluginIds"],
        "type": "object",
        "properties": {
          "model": {
            "type": "string"
          },
          "pluginIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "WebGenerateClassesRequest": {
        "required": ["languages"],
        "type": "object",
        "properties": {
          "languages": {
            "type": ["null", "array"],
            "items": {
              "type": "string"
            }
          },
          "transferFormat": {
            "type": ["null", "string"]
          }
        }
      },
      "WebGetContextResponse": {
        "required": ["data"],
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WebContextSlice"
            }
          }
        }
      },
      "WebGetInstalledPluginsResponse": {
        "required": ["data"],
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WebInstalledPlugin"
            }
          }
        }
      },
      "WebInstalledPlugin": {
        "required": ["folderPath", "id", "version", "manifest"],
        "type": "object",
        "properties": {
          "folderPath": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "manifest": {
            "$ref": "#/components/schemas/WebInstalledPluginManifest"
          }
        }
      },
      "WebInstalledPluginManifest": {
        "required": ["apiVersion", "name", "description", "author", "extensionPoints"],
        "type": "object",
        "properties": {
          "apiVersion": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": ["null", "string"]
          },
          "author": {
            "type": ["null", "string"]
          },
          "extensionPoints": {
            "type": "array"
          }
        }
      },
      "WebInstallPluginCommand": {
        "required": ["pluginId", "version"],
        "type": "object",
        "properties": {
          "pluginId": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "WebLinkContextCommand": {
        "required": ["linkerIds"],
        "type": "object",
        "properties": {
          "linkerIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "WebLoadContextCommand": {
        "required": ["filesToLoad"],
        "type": "object",
        "properties": {
          "filesToLoad": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "WebRunAnalysisCommand": {
        "required": ["projectId", "scriptId"],
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string"
          },
          "scriptId": {
            "type": "string"
          }
        }
      },
      "WebRunAnalysisResponse": {
        "required": ["id", "projectId", "scriptId", "status", "creationDate"],
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "projectId": {
            "type": "string"
          },
          "scriptId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "creationDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Plugins"
    },
    {
      "name": "Context"
    },
    {
      "name": "Analysis"
    }
  ]
}
