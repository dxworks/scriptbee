{
  "openapi": "3.1.1",
  "info": {
    "title": "ScriptBee Analysis API",
    "description": "API for ScriptBee Analysis service.",
    "version": "v2"
  },
  "servers": [
    {
      "url": "http://localhost:5002/"
    }
  ],
  "paths": {
    "/api/plugins": {
      "get": {
        "tags": [
          "Plugins"
        ],
        "summary": "Get installed plugins",
        "description": "Retrieves a list of all plugins currently installed in the analysis service.",
        "operationId": "PluginsGet",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetInstalledPluginsResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Plugins"
        ],
        "summary": "Install a plugin",
        "description": "Installs a specific plugin version into the analysis service.",
        "operationId": "PluginsPost",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InstallPluginCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/plugins/{pluginId}": {
      "delete": {
        "tags": [
          "Plugins"
        ],
        "summary": "Uninstall a plugin",
        "description": "Uninstalls a specific plugin version from the analysis service.",
        "operationId": "PluginsDelete",
        "parameters": [
          {
            "name": "pluginId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/api/context/clear": {
      "post": {
        "tags": [
          "Context"
        ],
        "summary": "Clear analysis context",
        "description": "Clears all data from the current analysis context.",
        "operationId": "Clear",
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/api/context/generate-classes": {
      "post": {
        "tags": [
          "Context"
        ],
        "summary": "Generate classes for analysis context",
        "description": "Generates script classes based on the current data context and returns them as a stream.",
        "operationId": "GenerateClasses",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateClassesRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/context": {
      "get": {
        "tags": [
          "Context"
        ],
        "summary": "Get analysis context",
        "description": "Retrieves the current data context from the analysis service.",
        "operationId": "Context",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetContextResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/context/graph-nodes": {
      "get": {
        "tags": [
          "Context",
          "Graph"
        ],
        "summary": "Search context nodes",
        "description": "Searches for context nodes based on a query string.",
        "operationId": "GraphNodes",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string",
              "default": ""
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContextGraphResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/context/graph-nodes/{nodeId}/neighbors": {
      "get": {
        "tags": [
          "Context",
          "Graph"
        ],
        "summary": "Get node neighbors",
        "description": "Retrieves the immediate neighbors and edges for a specific context node.",
        "operationId": "Neighbors",
        "parameters": [
          {
            "name": "nodeId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContextGraphResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/context/link": {
      "post": {
        "tags": [
          "Context"
        ],
        "summary": "Link analysis context",
        "description": "Links the current analysis context using the provided linkers.",
        "operationId": "Link",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LinkContextCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/context/load": {
      "post": {
        "tags": [
          "Context"
        ],
        "summary": "Load data into analysis context",
        "description": "Loads data from files into the current analysis context using the provided loaders.",
        "operationId": "Load",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoadContextCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/analyses": {
      "post": {
        "tags": [
          "Analysis"
        ],
        "summary": "Run analysis",
        "description": "Starts the execution of an analysis script on the analysis service.",
        "operationId": "Analyses",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RunAnalysisCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunAnalysisResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ContextGraphEdge": {
        "required": [
          "source",
          "target",
          "label"
