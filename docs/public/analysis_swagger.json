{
  "openapi": "3.1.1",
  "info": {
    "title": "ScriptBee Analysis API",
    "description": "API for ScriptBee Analysis service, responsible for running scripts and processing data.",
    "version": "v2"
  },
  "servers": [
    {
      "url": "http://localhost:5002/"
    }
  ],
  "paths": {
    "/api/plugins": {
      "get": {
        "tags": ["Plugins"],
        "summary": "Get installed plugins",
        "description": "Retrieves a list of all plugins currently installed in the analysis service.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetInstalledPluginsResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Plugins"],
        "summary": "Install a plugin",
        "description": "Installs a specific plugin version into the analysis service.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InstallPluginCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/plugins/{pluginId}": {
      "delete": {
        "tags": ["Plugins"],
        "summary": "Uninstall a plugin",
        "description": "Uninstalls a specific plugin version from the analysis service.",
        "parameters": [
          {
            "name": "pluginId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/api/context/clear": {
      "post": {
        "tags": ["Context"],
        "summary": "Clear analysis context",
        "description": "Clears all data from the current analysis context.",
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/api/context/generate-classes": {
      "post": {
        "tags": ["Context"],
        "summary": "Generate classes for analysis context",
        "description": "Generates script classes based on the current data context and returns them as a stream.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateClassesRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/context": {
      "get": {
        "tags": ["Context"],
        "summary": "Get analysis context",
        "description": "Retrieves the current data context from the analysis service.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetContextResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/context/graph-nodes": {
      "get": {
        "tags": ["Context", "Graph"],
        "summary": "Search context nodes",
        "description": "Searches for context nodes based on a query string.",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "skip",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": ["integer", "string"],
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "take",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": ["integer", "string"],
              "format": "int32",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContextGraphResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/context/graph-nodes/{nodeId}/neighbors": {
      "get": {
        "tags": ["Context", "Graph"],
        "summary": "Get node neighbors",
        "description": "Retrieves the immediate neighbors and edges for a specific context node.",
        "parameters": [
          {
            "name": "nodeId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContextGraphResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/context/link": {
      "post": {
        "tags": ["Context"],
        "summary": "Link analysis context",
        "description": "Links the current analysis context using the provided linkers.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LinkContextCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/context/load": {
      "post": {
        "tags": ["Context"],
        "summary": "Load data into analysis context",
        "description": "Loads data from files into the current analysis context using the provided loaders.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoadContextCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/analyses": {
      "post": {
        "tags": ["Analysis"],
        "summary": "Run analysis",
        "description": "Starts the execution of an analysis script on the analysis service.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RunAnalysisCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunAnalysisResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ContextGraphEdge": {
        "required": ["source", "target", "label"],
        "type": "object",
        "properties": {
          "source": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        }
      },
      "ContextGraphNode": {
        "required": ["id", "label", "type", "loader", "properties"],
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "loader": {
            "type": ["null", "string"]
          },
          "properties": {
            "type": "object"
          }
        }
      },
      "ContextGraphResponse": {
        "required": ["nodes", "edges"],
        "type": "object",
        "properties": {
          "nodes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContextGraphNode"
            }
          },
          "edges": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContextGraphEdge"
            }
          }
        }
      },
      "ContextSlice": {
        "required": ["model", "pluginIds"],
        "type": "object",
        "properties": {
          "model": {
            "type": "string"
          },
          "pluginIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "GenerateClassesRequest": {
        "required": ["languages"],
        "type": "object",
        "properties": {
          "languages": {
            "type": ["null", "array"],
            "items": {
              "type": "string"
            }
          },
          "transferFormat": {
            "type": ["null", "string"]
          }
        }
      },
      "GetContextResponse": {
        "required": ["data"],
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContextSlice"
            }
          }
        }
      },
      "GetInstalledPluginsResponse": {
        "required": ["data"],
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InstalledPlugin"
            }
          }
        }
      },
      "HttpValidationProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": ["null", "string"]
          },
          "title": {
            "type": ["null", "string"]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": ["null", "integer", "string"],
            "format": "int32"
          },
          "detail": {
            "type": ["null", "string"]
          },
          "instance": {
            "type": ["null", "string"]
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "InstalledPlugin": {
        "required": ["folderPath", "id", "version", "manifest"],
        "type": "object",
        "properties": {
          "folderPath": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "manifest": {
            "$ref": "#/components/schemas/InstalledPluginManifest"
          }
        }
      },
      "InstalledPluginManifest": {
        "required": ["apiVersion", "name", "description", "author", "extensionPoints"],
        "type": "object",
        "properties": {
          "apiVersion": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": ["null", "string"]
          },
          "author": {
            "type": ["null", "string"]
          },
          "extensionPoints": {
            "type": "array"
          }
        }
      },
      "InstallPluginCommand": {
        "required": ["pluginId", "version"],
        "type": "object",
        "properties": {
          "pluginId": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "LinkContextCommand": {
        "required": ["linkerIds"],
        "type": "object",
        "properties": {
          "linkerIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "LoadContextCommand": {
        "required": ["filesToLoad"],
        "type": "object",
        "properties": {
          "filesToLoad": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": ["null", "string"]
          },
          "title": {
            "type": ["null", "string"]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": ["null", "integer", "string"],
            "format": "int32"
          },
          "detail": {
            "type": ["null", "string"]
          },
          "instance": {
            "type": ["null", "string"]
          }
        }
      },
      "RunAnalysisCommand": {
        "required": ["projectId", "scriptId"],
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string"
          },
          "scriptId": {
            "type": "string"
          }
        },
        "description": "Command used to run an analysis script on the analysis service."
      },
      "RunAnalysisResponse": {
        "required": ["id", "projectId", "scriptId", "status", "creationDate"],
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "projectId": {
            "type": "string"
          },
          "scriptId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "creationDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Plugins"
    },
    {
      "name": "Context"
    },
    {
      "name": "Graph"
    },
    {
      "name": "Analysis"
    }
  ]
}
