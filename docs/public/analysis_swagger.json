        "type": "object",
        "properties": {
          "source": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        }
      },
      "ContextGraphNode": {
        "required": [
          "id",
          "label",
          "type",
          "loader",
          "properties"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "loader": {
            "type": [
              "null",
              "string"
            ]
          },
          "properties": {
            "type": "object"
          }
        }
      },
      "ContextGraphResponse": {
        "required": [
          "nodes",
          "edges"
        ],
        "type": "object",
        "properties": {
          "nodes": {
            "type": "array",
